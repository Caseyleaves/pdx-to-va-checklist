let doneData={},customTasks={},userName=localStorage.getItem("pdx_va_name")||"",activeCat="all",expanded=new Set(),allExp=false,loaded=false;
function initName(){if(userName){document.getElementById("nameOverlay").style.display="none";document.getElementById("userNameDisplay").textContent="Checking in as "+userName;}}
document.getElementById("nameSubmit").onclick=()=>{const v=document.getElementById("nameInput").value.trim();if(!v)return;userName=v;localStorage.setItem("pdx_va_name",v);document.getElementById("nameOverlay").style.display="none";document.getElementById("userNameDisplay").textContent="Checking in as "+v;};
document.getElementById("nameInput").addEventListener("keydown",e=>{if(e.key==="Enter")document.getElementById("nameSubmit").click();});
window.resetName=()=>{localStorage.removeItem("pdx_va_name");userName="";document.getElementById("nameInput").value="";document.getElementById("nameOverlay").style.display="flex";};
initName();
function setSS(s){const dot=document.getElementById("syncDot"),lbl=document.getElementById("syncLabel"),ban=document.getElementById("offlineBanner");if(s==="live"){dot.className="sync-dot live";lbl.textContent="Live";ban.classList.remove("show");}else if(s==="syncing"){dot.className="sync-dot syncing";lbl.textContent="Saving...";}else{dot.className="sync-dot";lbl.textContent="Offline";ban.classList.add("show");}}
onValue(doneRef,s=>{doneData=s.val()||{};setSS("live");if(loaded){updateProg();render();}},()=>setSS("offline"));
onValue(customRef,s=>{customTasks=s.val()||{};loaded=true;updateProg();buildChips();render();},()=>setSS("offline"));
function allItems(){const c=Object.entries(customTasks).map(([id,t])=>({id,date:t.date||"Jun 23+",cat:"custom",deadline:false,title:t.title,lines:t.lines||[],iso:t.iso||"2026-06-23",addedBy:t.addedBy,isCustom:true}));return[...B.map((t,i)=>({...t,id:"b"+i})),...c];}
function isoToLabel(iso){if(!iso)return"Jun 23+";const d=new Date(iso+"T12:00:00"),days=["Sun","Mon","Tue","Wed","Thu","Fri","Sat"],months=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug"],lbl=days[d.getDay()]+" "+months[d.getMonth()]+" "+d.getDate();return DOR.includes(lbl)?lbl:"Jun 23+";}
function gcal(title,iso,lines){const d=(iso||"2026-06-23").replace(/-/g,""),dt=new Date((iso||"2026-06-23")+"T12:00:00");dt.setDate(dt.getDate()+1);const nd=dt.toISOString().slice(0,10).replace(/-/g,"");return"https://calendar.google.com/calendar/render?action=TEMPLATE&text="+encodeURIComponent(title)+"&dates="+d+"/"+nd+"&details="+encodeURIComponent((lines||[]).join("
"));}
function updateProg(){const items=allItems(),total=items.length,dc=items.filter(i=>doneData[i.id]).length,pct=total?Math.round(dc/total*100):0;document.getElementById("pfill").style.width=pct+"%";document.getElementById("plabel").textContent=dc+" / "+total+" done";}
function toggleDone(id){setSS("syncing");const upd={};if(doneData[id]){upd[id]=null;doneData={...doneData};delete doneData[id];}else{upd[id]={by:userName||"Someone",at:Date.now()};doneData={...doneData,[id]:upd[id]};}update(doneRef,upd).then(()=>setSS("live")).catch(()=>setSS("offline"));updateProg();render();}
function buildChips(){const items=allItems(),el=document.getElementById("chips"),cats=["all",...Object.keys(CATS),"deadlines"];el.innerHTML="";cats.forEach(cat=>{const count=cat==="all"?items.length:cat==="deadlines"?items.filter(i=>i.deadline).length:items.filter(i=>i.cat===cat).length;if(count===0&&cat!=="all")return;const b=document.createElement("button");b.className="chip"+(cat===activeCat?" active":"");const lbl=cat==="all"?"All":cat==="deadlines"?"Deadlines":CATS[cat]?.label||cat;b.textContent=lbl+" "+count;b.onclick=()=>{activeCat=cat;buildChips();render();};el.appendChild(b);});}
function render(){const q=document.getElementById("srch").value.toLowerCase(),items=allItems();let f=items.filter(item=>{if(activeCat==="deadlines"&&!item.deadline)return false;if(activeCat!=="all"&&activeCat!=="deadlines"&&item.cat!==activeCat)return false;if(q)return item.title.toLowerCase().includes(q)||(item.lines||[]).some(l=>l.toLowerCase().includes(q));return true;});const dc=f.filter(i=>doneData[i.id]).length,dl=f.filter(i=>i.deadline).length;document.getElementById("sumbar").innerHTML="<span class='stat'><strong>"+f.length+"</strong> tasks</span><span class='stat'><strong>"+dl+"</strong> deadlines</span><span class='stat'><strong>"+(f.length-dc)+"</strong> remaining</span>";const tl=document.getElementById("tl");tl.innerHTML="";if(!f.length){tl.innerHTML="<div class='empty'>No tasks match.</div>";return;}const grouped={};DOR.forEach(d=>{const di=f.filter(i=>i.date===d||(d==="Jun 23+"&&!DOR.slice(0,-1).includes(i.date)));if(di.length)grouped[d]=di;});Object.entries(grouped).forEach(([date,items])=>{const block=document.createElement("div");block.className="date-block";const hdr=document.createElement("div");hdr.className="date-hdr";hdr.innerHTML="<span class='date-label'>"+date+"</span><div class='date-line'></div><span class='date-count'>"+items.length+"</span>";block.appendChild(hdr);items.forEach(item=>{const id=item.id,de=doneData[id],isDone=!!de,isOpen=expanded.has(id),cat=CATS[item.cat]||CATS.custom,card=document.createElement("div");card.className="task-card"+(isDone?" done":"")+(item.deadline?" deadline-card":"")+(item.isCustom?" custom-card":"");card.style.borderLeftColor=cat.c;const top=document.createElement("div");top.className="task-top";top.onclick=e=>{if(e.target.closest(".checkbox"))return;if(expanded.has(id))expanded.delete(id);else expanded.add(id);render();};const cb=document.createElement("div");cb.className="checkbox"+(isDone?" checked":"");cb.innerHTML="<svg width='13' height='10' viewBox='0 0 13 10' fill='none'><path d='M1.5 5L5 8.5L11.5 1.5' stroke='white' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'/></svg>";cb.onclick=e=>{e.stopPropagation();toggleDone(id);};const meta=document.createElement("div");meta.className="task-meta";const tt=document.createElement("div");tt.className="task-title";tt.textContent=item.title;const badges=document.createElement("div");badges.className="task-badges";const cp=document.createElement("span");cp.className="badge";cp.style.cssText="background:"+cat.bg+";color:"+cat.tc;cp.textContent=cat.label;badges.appendChild(cp);if(item.deadline){const dp=document.createElement("span");dp.className="badge deadline-pill";dp.textContent="Hard deadline";badges.appendChild(dp);}if(item.isCustom){const xp=document.createElement("span");xp.className="badge custom-pill";xp.textContent="Added by "+(item.addedBy||"us");badges.appendChild(xp);}if(isDone&&de.by){const wp=document.createElement("span");wp.className="badge who-pill";wp.textContent="checkmark "+de.by;badges.appendChild(wp);}meta.appendChild(tt);meta.appendChild(badges);const chev=document.createElement("div");chev.className="chevron"+(isOpen?" open":"");chev.textContent="v";top.appendChild(cb);top.appendChild(meta);top.appendChild(chev);const body=document.createElement("div");body.className="task-body"+(isOpen?" open":"");const ld=document.createElement("div");ld.className="task-lines";(item.lines||[]).forEach(line=>{const l=document.createElement("div");l.className="task-line";l.textContent=line;ld.appendChild(l);});const acts=document.createElement("div");acts.className="task-actions";const ca=document.createElement("a");ca.className="cal-btn";ca.href=gcal(item.title,item.iso,item.lines);ca.target="_blank";ca.rel="noopener";ca.textContent="Add to Google Calendar";acts.appendChild(ca);const db=document.createElement("button");db.className="done-btn"+(isDone?" undo":"");db.textContent=isDone?"Undo":"Mark done";db.onclick=()=>toggleDone(id);acts.appendChild(db);body.appendChild(ld);body.appendChild(acts);card.appendChild(top);card.appendChild(body);block.appendChild(card);});tl.appendChild(block);});}
function openAdd(){document.getElementById("addOverlay").classList.add("show");document.getElementById("newTitle").focus();}
function closeAdd(){document.getElementById("addOverlay").classList.remove("show");document.getElementById("newTitle").value="";document.getElementById("newDetails").value="";document.getElementById("newDate").value="";}
document.getElementById("openAddTop").onclick=openAdd;
document.getElementById("openAddFab").onclick=openAdd;
document.getElementById("cancelAdd").onclick=closeAdd;
document.getElementById("addOverlay").onclick=e=>{if(e.target===document.getElementById("addOverlay"))closeAdd();};
document.getElementById("saveAdd").onclick=()=>{const title=document.getElementById("newTitle").value.trim();if(!title){document.getElementById("newTitle").focus();return;}const raw=document.getElementById("newDetails").value.trim();const lines=raw?raw.split("
").map(l=>l.trim()).filter(Boolean):[];const dateVal=document.getElementById("newDate").value;const iso=dateVal||"2026-06-23";const dateLabel=isoToLabel(iso);const task={title,lines,date:dateLabel,iso,addedBy:userName||"Someone",createdAt:Date.now()};setSS("syncing");push(customRef,task).then(()=>{setSS("live");closeAdd();}).catch(()=>setSS("offline"));};
document.getElementById("expandBtn").onclick=()=>{if(allExp){expanded.clear();document.getElementById("expandBtn").textContent="Expand all";allExp=false;}else{allItems().forEach(i=>expanded.add(i.id));document.getElementById("expandBtn").textContent="Collapse all";allExp=true;}render();};
document.getElementById("srch").addEventListener("input",render);
</script>
