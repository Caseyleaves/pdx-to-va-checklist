    <div class="modal-actions"><button class="btn-cancel" id="cancelAdd">Cancel</button><button class="btn-save" id="saveAdd">Add task</button></div>
  </div>
</div>
<div class="header">
  <div class="header-top">
    <div><h1>PDX To VA Moving Checklist</h1><p>Portland OR &rarr; Mattaponi VA &bull; May 28 &ndash; June 22, 2026</p></div>
