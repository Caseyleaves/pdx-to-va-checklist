<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#1a1a2e">
<title>PDX To VA Moving Checklist</title>
<style>
  :root { --bg:#f7f8fa; --card:#fff; --text:#1a1a2e; --muted:#6b7280; --border:#e5e7eb; --radius:12px; }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
  .header{background:#1a1a2e;color:#fff;padding:18px 16px 12px;position:sticky;top:0;z-index:100}
  .header-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
  .header h1{font-size:16px;font-weight:700;letter-spacing:-.3px;line-height:1.2}
  .header p{font-size:11px;color:rgba(255,255,255,.5);margin-top:2px}
  .sync-info{text-align:right;flex-shrink:0}
  .sync-row{display:flex;align-items:center;gap:5px;justify-content:flex-end}
  .sync-dot{width:7px;height:7px;border-radius:50%;background:#6b7280;transition:background .3s}
  .sync-dot.live{background:#4ade80}
  .sync-dot.syncing{background:#fbbf24;animation:pulse .8s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
  .sync-label{font-size:10px;color:rgba(255,255,255,.4)}
  .user-name{font-size:10px;color:rgba(255,255,255,.5);margin-top:2px;cursor:pointer}
  .progress-row{display:flex;align-items:center;gap:10px;margin-top:10px}
  .progress-bar{flex:1;height:4px;background:rgba(255,255,255,.15);border-radius:99px;overflow:hidden}
  .progress-fill{height:100%;background:#4ade80;border-radius:99px;transition:width .4s ease}
  .progress-label{font-size:11px;color:rgba(255,255,255,.6);white-space:nowrap}
  .offline-banner{background:#fef3c7;border-bottom:1px solid #fde68a;padding:7px 16px;font-size:12px;color:#92400e;display:none}
  .offline-banner.show{display:block}
  .controls{padding:10px 16px 6px;display:flex;flex-direction:column;gap:7px}
  .search-row{display:flex;gap:7px}
  .search-input{flex:1;padding:9px 12px;border:1.5px solid var(--border);border-radius:10px;font-size:15px;background:var(--card);color:var(--text);outline:none}
  .search-input:focus{border-color:#6366f1}
  .add-btn-top{padding:9px 14px;border-radius:10px;background:#22c55e;color:#fff;border:none;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap}
  .filter-scroll{display:flex;gap:5px;overflow-x:auto;padding-bottom:2px;scrollbar-width:none}
  .filter-scroll::-webkit-scrollbar{display:none}
  .chip{padding:5px 12px;border-radius:20px;border:1.5px solid var(--border);background:var(--card);color:var(--muted);font-size:11px;font-weight:500;cursor:pointer;white-space:nowrap;flex-shrink:0}
  .chip.active{border-color:#1a1a2e;background:#1a1a2e;color:#fff}
  .summary-bar{display:flex;gap:5px;padding:0 16px 6px;flex-wrap:wrap}
  .stat{font-size:11px;color:var(--muted);background:var(--card);border:1px solid var(--border);border-radius:7px;padding:3px 9px}
  .stat strong{color:var(--text)}
  .timeline{padding:0 16px 120px}
  .date-block{margin-bottom:2px}
  .date-hdr{display:flex;align-items:center;gap:8px;padding:12px 0 5px}
  .date-label{font-size:12px;font-weight:700;color:var(--text)}
  .date-line{flex:1;height:1px;background:var(--border)}
  .date-count{font-size:10px;color:var(--muted);background:var(--border);border-radius:99px;padding:2px 7px}
  .task-card{background:var(--card);border-radius:var(--radius);border:1px solid var(--border);border-left:4px solid;margin-bottom:7px;overflow:hidden;transition:opacity .2s}
  .task-card.done{opacity:.5;background:#f0fdf4}
  .task-card.deadline-card{box-shadow:0 0 0 1px rgba(220,38,38,.1)}
  .task-card.custom-card{border-left-style:dashed}
  .task-top{display:flex;align-items:flex-start;gap:11px;padding:12px 12px 9px;cursor:pointer;user-select:none}
  .checkbox{width:26px;height:26px;min-width:26px;border-radius:7px;border:2px solid var(--border);background:#fff;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:all .15s;cursor:pointer;flex-shrink:0}
  .checkbox.checked{background:#22c55e;border-color:#22c55e}
  .checkbox svg{display:none}
  .checkbox.checked svg{display:block}
  .task-meta{flex:1;min-width:0}
  .task-title{font-size:14px;font-weight:600;color:var(--text);line-height:1.3}
  .task-card.done .task-title{text-decoration:line-through;color:var(--muted)}
  .task-badges{display:flex;flex-wrap:wrap;gap:3px;margin-top:5px}
  .badge{font-size:10px;font-weight:600;padding:2px 7px;border-radius:99px}
  .deadline-pill{background:#fef2f2;color:#dc2626}
  .custom-pill{background:#f0fdf4;color:#16a34a}
  .who-pill{background:#f3f4f6;color:#6b7280}
  .chevron{color:var(--muted);font-size:18px;margin-top:2px;transition:transform .2s;flex-shrink:0;line-height:1}
  .chevron.open{transform:rotate(180deg)}
  .task-body{padding:0 12px;max-height:0;overflow:hidden;transition:max-height .25s ease}
  .task-body.open{max-height:700px;padding-bottom:12px}
  .task-lines{display:flex;flex-direction:column;gap:4px;border-top:1px solid var(--border);padding-top:9px}
  .task-line{font-size:13px;color:#374151;line-height:1.4;padding-left:13px;position:relative}
  .task-line::before{content:"--";position:absolute;left:0;color:#9ca3af}
  .task-actions{display:flex;gap:7px;margin-top:10px;flex-wrap:wrap}
  .cal-btn{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:500;padding:7px 11px;border-radius:8px;background:#eff6ff;color:#1d4ed8;text-decoration:none;border:1px solid #bfdbfe}
  .done-btn{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:500;padding:7px 11px;border-radius:8px;background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;cursor:pointer}
  .done-btn.undo{background:#fef2f2;color:#dc2626;border-color:#fecaca}
  .empty{text-align:center;padding:40px 16px;color:var(--muted);font-size:14px}
  .loading{text-align:center;padding:60px 16px;color:var(--muted);font-size:14px}
  .fab-group{position:fixed;bottom:20px;right:16px;display:flex;flex-direction:column;align-items:flex-end;gap:10px;z-index:200}
  .fab{border:none;border-radius:14px;padding:12px 16px;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 4px 16px rgba(0,0,0,.2)}
  .fab-add{background:#22c55e;color:#fff}
  .fab-expand{background:#1a1a2e;color:#fff}
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:400;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s}
  .modal-overlay.show{opacity:1;pointer-events:all}
  .modal{background:#fff;border-radius:20px 20px 0 0;padding:24px 20px 40px;width:100%;max-width:520px;transform:translateY(100%);transition:transform .25s ease}
  .modal-overlay.show .modal{transform:translateY(0)}
  .modal h2{font-size:18px;font-weight:700;margin-bottom:18px}
  .form-field{margin-bottom:14px}
  .form-label{font-size:11px;font-weight:600;color:var(--muted);margin-bottom:5px;display:block;text-transform:uppercase;letter-spacing:.04em}
  .form-input{width:100%;padding:11px 13px;border:1.5px solid var(--border);border-radius:10px;font-size:15px;color:var(--text);background:#fff;outline:none;font-family:inherit}
  .form-input:focus{border-color:#6366f1}
  textarea.form-input{min-height:80px;resize:vertical}
  .modal-actions{display:flex;gap:10px;margin-top:6px}
  .btn-cancel{flex:1;padding:13px;border:1.5px solid var(--border);border-radius:10px;background:#fff;color:var(--muted);font-size:15px;font-weight:600;cursor:pointer}
  .btn-save{flex:2;padding:13px;border:none;border-radius:10px;background:#1a1a2e;color:#fff;font-size:15px;font-weight:600;cursor:pointer}
  .name-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:500;display:flex;align-items:center;justify-content:center;padding:24px}
  .name-modal{background:#fff;border-radius:18px;padding:28px 22px;width:100%;max-width:340px}
  .name-modal h2{font-size:20px;font-weight:700;margin-bottom:6px}
  .name-modal p{font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.5}
  .name-input{width:100%;padding:13px;border:1.5px solid var(--border);border-radius:10px;font-size:16px;outline:none;margin-bottom:12px;font-family:inherit}
  .name-input:focus{border-color:#6366f1}
  .name-submit{width:100%;padding:14px;background:#1a1a2e;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:600;cursor:pointer}
</style>
</head>
<body>
