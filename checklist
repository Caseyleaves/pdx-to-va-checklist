    </div>
  </div>
  <div class="progress-row"><div class="progress-bar"><div class="progress-fill" id="pfill" style="width:0%"></div></div><span class="progress-label" id="plabel">Loading...</span></div>
</div>
<div class="offline-banner" id="offlineBanner">&#9888; Offline -- changes will sync when reconnected</div>
<div class="controls">
  <div class="search-row"><input class="search-input" id="srch" type="search" placeholder="Search tasks..." autocomplete="off"><button class="add-btn-top" id="openAddTop">+ Add</button></div>
  <div class="filter-scroll" id="chips"></div>
</div>
<div class="summary-bar" id="sumbar"></div>
<div class="timeline" id="tl"><div class="loading">Connecting to Firebase...</div></div>
<div class="fab-group"><button class="fab fab-add" id="openAddFab">+ Add task</button><button class="fab fab-expand" id="expandBtn">Expand all</button></div>
